# OpenAI-compatible API.
# Keep real keys in .env locally and GitHub Secrets remotely.
OPENALEX_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=http://152.53.240.99:8080
OPENAI_MODEL=gpt-5.5

# NetEase 163 SMTP.
SMTP_SERVER=smtp.163.com
SMTP_EMAIL=agonyy2026@163.com
SMTP_AUTH_CODE=
MAIL_TO=agony2023@qq.com
MAIL_FROM_NAME=Academic Daily Scholar
MAIL_ENABLED=true


# Runtime.
TIMEZONE=Asia/Shanghai
RUN_TIME=08:00
MAX_PAPERS=5
SEARCH_MONTHS=3
PUBLICATION_YEARS=1
PRIMARY_SEARCH_DAYS=3
FALLBACK_SEARCH_YEARS=3
SEEN_STATE_PATH=data/seen_papers.json
REQUEST_TIMEOUT_SECONDS=30
REQUEST_RETRIES=3
OPENAI_TIMEOUT_SECONDS=90

# SSCI whitelist.
# Local Windows example:
SSCI_WHITELIST_PATH=data/ssci_whitelist_2026-06.xlsx
# off: do not use whitelist; prefer: rank whitelist papers higher; strict: only keep whitelist matches when file is available.
SSCI_FILTER_MODE=strict
